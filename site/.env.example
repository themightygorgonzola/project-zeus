# Environment — copy to .env and fill in values
# Turso (hosted SQLite)
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google

# Discord OAuth 2.0
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback/discord

# OpenAI (for AI proxy)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_INTERACTIVE=gpt-4o
OPENAI_MODEL_BACKGROUND=gpt-4o

# AI routing
# interactive-chat defaults to inline for fast first feedback
AI_INTERACTIVE_MODE=inline

# Local development auth
# Auto-enabled in `vite dev` mode. Set explicitly if you want seeded
# test accounts on a deployed preview.  NEVER set "true" on production.
ENABLE_DEV_AUTH=true

# Trigger.dev  (https://cloud.trigger.dev — get your dev key from the project dashboard)
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxxxxxxxx

# PartyKit
# In dev: keep as localhost:1999 (partykit dev server)
# In production: set to your deployed host, e.g. project-zeus.YOUR-USERNAME.partykit.dev
PUBLIC_PARTYKIT_HOST=localhost:1999
PARTYKIT_HOST=localhost:1999
